# Email Configuration (Required for form submissions)
# For Gmail: Use an App Password, not your regular password
# https://support.google.com/accounts/answer/185833

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Admin email where form notifications will be sent
ADMIN_EMAIL=admin@bknbeautyacademy.co.za

# reCAPTCHA Configuration (Optional for development, Required for production)
# Get keys from: https://www.google.com/recaptcha/admin
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
NUXT_RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Site URL
NUXT_PUBLIC_SITE_URL=https://www.bknbeautyacademy.co.za

# Google Drive Configuration (Optional - Currently Disabled)
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_DRIVE_REDIRECT_URI=
# GOOGLE_DRIVE_REFRESH_TOKEN=
